#include <stdio.h>

typedef struct CATALOGO {

	char nome[20];
	float preco;
	int estoque;
	int codigo; 

} PRODUTO;


int REDUZ_ESTOQUE(int quant_estoque, int quantos_reduzir) {
	quant_estoque -= quantos_reduzir;
	return quant_estoque;
}

void MOSTRA_PROD(PRODUTO p1) {
	printf("\n------------------\n");
	printf("NOME: %s\n", p1.nome);
	printf("PRECO: %.2f\n", p1.preco);
	printf("ESTOQUE: %d\n", p1.estoque);
	printf("CODIGO: %d\n", p1.codigo);
	printf("------------------\n");
}

int main() {

	PRODUTO p1[10];

	int choise1;
	int i; // precisa existir fora dos loops
	int totalProdutos = 0; // controla quantidade cadastrada

	do {
		printf("----------------------------\n");
		printf("   CONTROLE DE ESTOQUE\n");
		printf("----------------------------\n");
		printf("1 - Cadastrar produto\n");
		printf("2 - Mostrar produtos\n");
		printf("3 - Alterar estoque\n");
		printf("4 - Sair\n");
		printf("----------------------------\n");

		scanf("%d", &choise1);

		// CADASTRO
		if (choise1 == 1) {

			int n;

			printf("Quantos produtos gostaria de cadastrar?\n");
			scanf("%d", &n);

			for (i = 0; i < n; i++) {

				printf("NOME: ");
				scanf("%s", p1[totalProdutos].nome);

				printf("PRECO: ");
				scanf("%f", &p1[totalProdutos].preco);

				printf("QUANTIDADE EM ESTOQUE: ");
				scanf("%d", &p1[totalProdutos].estoque);

				// código sequencial correto
				p1[totalProdutos].codigo = totalProdutos + 1;

				printf("CODIGO DO PRODUTO: %d\n", p1[totalProdutos].codigo);

				totalProdutos++;
			}
		}

		// EXIBIR PRODUTOS
		else if (choise1 == 2) {

			for (i = 0; i < totalProdutos; i++) {
				MOSTRA_PROD(p1[i]);
			}
		}

		// ALTERAR ESTOQUE
		else if (choise1 == 3) {

			int codigo_temp, valor_temp;

			printf("Qual o codigo do produto?\n");
			scanf("%d", &codigo_temp);

			printf("Qual valor deseja alterar no estoque?\n");
			printf("Use + para adicionar ou - para remover\n");
			scanf("%d", &valor_temp);

			for (i = 0; i < totalProdutos; i++) {

				if (p1[i].codigo == codigo_temp) {

					printf("Estoque atual: %d\n", p1[i].estoque);

					// usa sua função corretamente
					p1[i].estoque = REDUZ_ESTOQUE(p1[i].estoque, - valor_temp);

					printf("Novo estoque: %d\n", p1[i].estoque);
				}
			}
		}

	} while (choise1 != 4);

	return 0;
}